<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="680.0" prefWidth="950.0" style="-fx-background-color: #1e1e24;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.algoritmoordenamientokevin.Controlador.MainViewController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="15.0" />
            </BorderPane.margin>
            
            
            <Label text="Visualizador y Ordenador de Listas Enlazadas (IF-3001)" textFill="#f9fafb">
                <font>
                    <Font name="System Bold" size="22.0" />
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <VBox spacing="15.0" BorderPane.alignment="CENTER">
            
            <GridPane hgap="15.0" style="-fx-background-color: #2a2a35; -fx-border-color: #374151; -fx-border-radius: 5; -fx-background-radius: 5;" vgap="5.0">
                <padding>
                    <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                </padding>
                
                <Label text="1. Archivo" textFill="#9ca3af" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label text="2. Algoritmo" textFill="#9ca3af" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label text="3. Columna" textFill="#9ca3af" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label text="4. Dirección" textFill="#9ca3af" GridPane.columnIndex="3" GridPane.rowIndex="0">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>

                <ComboBox fx:id="comboArchivo" onAction="#handleSeleccionArchivo" prefWidth="150.0" styleClass="combo-dark" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="comboAlgoritmo" prefWidth="180.0" styleClass="combo-dark" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <ComboBox fx:id="comboColumna" prefWidth="150.0" styleClass="combo-dark" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <ComboBox fx:id="comboDireccion" prefWidth="120.0" styleClass="combo-dark" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                
                <Button mnemonicParsing="false" onAction="#handleEjecutarOrdenamiento" styleClass="btn-success" text="⚡ Ordenar Datos" textFill="#f9fafb" GridPane.columnIndex="4" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </GridPane>

            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Datos Originales (Desordenados)" textFill="#9ca3af">
                        <font><Font name="System Bold" size="14.0" /></font>
                    </Label>
                    <TableView fx:id="tablaOriginal" styleClass="table-dark" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colRegionOrig" prefWidth="220.0" text="Region (Col A)" />
                            <TableColumn fx:id="colUnitsOrig" prefWidth="220.0" text="Units Sold (Col B)" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Datos Ordenados" textFill="#9ca3af">
                        <font><Font name="System Bold" size="14.0" /></font>
                    </Label>
                    <TableView fx:id="tablaOrdenada" styleClass="table-dark" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colRegionOrd" prefWidth="220.0" text="Region (Col A)" />
                            <TableColumn fx:id="colUnitsOrd" prefWidth="220.0" text="Units Sold (Col B)" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <BorderPane style="-fx-background-color: #2a2a35; -fx-border-color: #374151; -fx-border-radius: 5; -fx-background-radius: 5;" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets top="15.0" />
            </BorderPane.margin>
            <padding>
                <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
            </padding>
            <left>
                <Label fx:id="lblStatus" text="Estado: Esperando carga de archivo CSV..." textFill="#f9fafb" BorderPane.alignment="CENTER">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
            </left>
            <right>
                <HBox alignment="CENTER_RIGHT" spacing="20.0" BorderPane.alignment="CENTER">
                    <Label fx:id="lblIteraciones" text="Iteraciones: —" textFill="#10b981">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <Label fx:id="lblTiempo" text="Tiempo: —" textFill="#10b981">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                </HBox>
            </right>
        </BorderPane>
    </bottom>
</BorderPane>
